# Release signing for `./gradlew :app:assembleRelease`.
# Copy to `android/keystore.properties` (gitignored) and fill in. The keystore
# itself should live OUTSIDE the repo — point `storeFile` at an absolute path.
# Alternatively, set the MYCO_RELEASE_* env vars (used by CI). See
# docs/how-to/publish.md.

storeFile=/absolute/path/to/myco-release.jks
storePassword=CHANGEME
keyAlias=myco
keyPassword=CHANGEME
