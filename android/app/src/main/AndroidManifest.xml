<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE: legacy permissions for API <= 30 -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />
    <!-- BLE: runtime permissions for API 31+ (scan declares it never derives location) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Foreground service hosting the BLE radio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- App-owned TUN: the VpnService routes only fd00::/8 (the mesh ULA). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- P2 content entry: fetch a pasted nsite link from public relays/Blossom
         over normal IP (the tier-3 online fallback). Browsing cached nsites needs
         no network. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- In-app QR scanner (reads a share QR). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- NFC tap-to-pair: HCE presents this device's pair code; reader mode reads a
         peer's. Both optional — the app falls back to QR/paste without NFC. -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />
    <uses-feature android:name="android.hardware.nfc.hce" android:required="false" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Myco">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Myco.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Handle scanned myco:// links (a share QR: open the nsite + carry the
                 sharer's pairing info). BROWSABLE so a camera/QR scanner can hand
                 it to Myco. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="myco" />
            </intent-filter>
            <!-- Tap-to-pair: the OS reads the presenter's NDEF URI tag and delivers
                 the myco://pair link here (no reader mode needed on this side). -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="myco" />
            </intent-filter>
        </activity>

        <!-- Each opened nsite runs as a fullscreen, chrome-less WebView in its own
             task, keyed by host (the document data URI) so re-opening — whether
             from the in-app list or a home-screen shortcut — re-surfaces the SAME
             Recents card. `intoExisting` reuses the task whose data URI matches;
             `always` would (wrongly) spawn a new task every launch. -->
        <activity
            android:name=".NsiteActivity"
            android:exported="false"
            android:documentLaunchMode="intoExisting"
            android:autoRemoveFromRecents="false"
            android:theme="@style/Theme.Myco.Splash"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/app_name" />

        <!-- Portrait-locked QR scanner (the zxing default opens sideways). -->
        <activity
            android:name=".PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true" />

        <service
            android:name=".ble.BleService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- HCE for NFC tap-to-pair: emulates a tag serving this device's
             myco://pair code while the QR/present screen is open. -->
        <service
            android:name=".nfc.PairHostApduService"
            android:exported="true"
            android:permission="android.permission.BIND_NFC_SERVICE">
            <intent-filter>
                <action android:name="android.nfc.cardemulation.action.HOST_APDU_SERVICE" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.cardemulation.host_apdu_service"
                android:resource="@xml/apduservice" />
        </service>

        <!-- The app-owned TUN. BIND_VPN_SERVICE + the android.net.VpnService
             intent-filter mark it as a VpnService; specialUse FGS keeps it alive. -->
        <service
            android:name=".vpn.MycoVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Mesh network adapter routing fd00::/8 over FIPS" />
            <!-- Disable the system "Always-on VPN" toggle for this VPN: the mesh
                 adapter is driven by the app, not meant to be forced always-on. -->
            <meta-data
                android:name="android.net.VpnService.SUPPORTS_ALWAYS_ON"
                android:value="false" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>
</manifest>
