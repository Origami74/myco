<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE: legacy permissions for API <= 30 -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />
    <!-- BLE: runtime permissions for API 31+ (scan declares it never derives location) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Foreground service hosting the BLE radio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- P2 content entry: fetch a pasted nsite link from public relays/Blossom
         over normal IP (the tier-3 online fallback). Browsing cached nsites needs
         no network. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Myco">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Each opened nsite runs as a fullscreen, chrome-less WebView in its own
             task (documentLaunchMode + FLAG_ACTIVITY_NEW_DOCUMENT), keyed by host
             so re-opening re-surfaces the same Recents card. Launched internally. -->
        <activity
            android:name=".NsiteActivity"
            android:exported="false"
            android:documentLaunchMode="always"
            android:autoRemoveFromRecents="false"
            android:label="@string/app_name" />

        <service
            android:name=".ble.BleService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />
    </application>
</manifest>
